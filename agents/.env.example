# Studio API Keys & Environments

# Gemini API Key (Required for all agents and Managed Agents runtime)
GEMINI_API_KEY=your_gemini_api_key_here

# Domainr API Key (Required for Namer agent domain checks)
DOMAINR_API_KEY=your_domainr_api_key_here

# Vercel Settings (Required for Developer agent to deploy projects)
VERCEL_TOKEN=your_vercel_api_token_here
VERCEL_PROJECT_ID=your_vercel_project_id_here

# Apollo Settings (Required for Growth agent prospect lookups)
APOLLO_API_KEY=your_apollo_api_key_here

# ----- Guardrails (backend) -------------------------------------------------
# When true, every agent uses fake streamers — zero API cost (dev mode).
# Defaults to false (real Gemini calls). Set MOCK_ONLY=true for free dev runs.
MOCK_ONLY=false

# Hard cap on POST /api/runs in a rolling 1-hour window. Returns 429 over limit.
MAX_RUNS_PER_HOUR=20
