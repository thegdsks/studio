{
  "meta": {
    "name": "studio-mission-control",
    "version": "2.0.0",
    "stitchAssetId": "15972727176921104973",
    "mode": "dark",
    "locked": true,
    "lockedBy": "docs-local/STYLE.md"
  },
  "color": {
    "bg": "#0A0A0F",
    "surface": "#0F1015",
    "surface-raised": "#15171F",
    "surface-sunken": "#08090E",

    "text": "#F2F4F8",
    "text-muted": "#A0A6B8",
    "text-faint": "#5E6478",
    "text-on-accent": "#0A0A0F",

    "border": "rgba(255, 255, 255, 0.06)",
    "border-strong": "rgba(255, 255, 255, 0.12)",
    "border-accent": "rgba(59, 130, 246, 0.45)",

    "accent": "#3B82F6",
    "accent-soft": "rgba(59, 130, 246, 0.18)",
    "accent-glow": "rgba(59, 130, 246, 0.35)",

    "status-queued": "#5E6478",
    "status-running": "#3B82F6",
    "status-running-soft": "rgba(59, 130, 246, 0.18)",
    "status-done": "#22C55E",
    "status-done-soft": "rgba(34, 197, 94, 0.18)",
    "status-warn": "#F59E0B",
    "status-error": "#EF4444",
    "status-error-soft": "rgba(239, 68, 68, 0.18)"
  },
  "status": {
    "queued":  { "fg": "status-queued",  "dot": "outlined" },
    "running": { "fg": "status-running", "dot": "pulsing",  "border": "border-accent", "glow": "accent-soft" },
    "done":    { "fg": "status-done",    "dot": "filled" },
    "error":   { "fg": "status-error",   "dot": "filled",   "border": "status-error" }
  },
  "font": {
    "display": "var(--font-geist), system-ui, -apple-system, sans-serif",
    "body":    "var(--font-geist), system-ui, -apple-system, sans-serif",
    "mono":    "var(--font-geist-mono), ui-monospace, 'SF Mono', monospace"
  },
  "typography": {
    "display-lg":  { "font": "display", "size": "64px", "weight": "600", "lineHeight": "1.05", "letterSpacing": "-0.035em" },
    "display-md":  { "font": "display", "size": "44px", "weight": "600", "lineHeight": "1.08", "letterSpacing": "-0.03em" },
    "headline-lg": { "font": "display", "size": "28px", "weight": "600", "lineHeight": "1.2",  "letterSpacing": "-0.02em" },
    "headline-md": { "font": "display", "size": "20px", "weight": "600", "lineHeight": "1.25", "letterSpacing": "-0.015em" },
    "title-md":    { "font": "body",    "size": "15px", "weight": "600", "lineHeight": "1.3",  "letterSpacing": "-0.01em" },
    "body-md":     { "font": "body",    "size": "14px", "weight": "400", "lineHeight": "1.55" },
    "body-sm":     { "font": "body",    "size": "13px", "weight": "400", "lineHeight": "1.5" },
    "mono-md":     { "font": "mono",    "size": "12.5px", "weight": "400", "lineHeight": "1.55" },
    "mono-sm":     { "font": "mono",    "size": "11.5px", "weight": "400", "lineHeight": "1.45" },
    "label-sm":    { "font": "mono",    "size": "10.5px", "weight": "500", "lineHeight": "1.2", "letterSpacing": "0.08em", "transform": "uppercase" }
  },
  "radius": {
    "none": "0",
    "sm":   "6px",
    "md":   "10px",
    "lg":   "14px",
    "xl":   "20px",
    "full": "9999px"
  },
  "space": {
    "0": "0",
    "0.5": "2px",
    "1":   "4px",
    "2":   "8px",
    "3":   "12px",
    "4":   "16px",
    "5":   "20px",
    "6":   "24px",
    "8":   "32px",
    "10":  "40px",
    "12":  "48px",
    "16":  "64px",
    "20":  "80px"
  },
  "size": {
    "agent-card-h": "220px",
    "agent-grid-gap": "16px",
    "page-gutter": "24px",
    "page-gutter-sm": "16px",
    "section-gap": "48px",
    "row-sm": "44px",
    "row-md": "64px",
    "max-w-prose": "640px",
    "max-w-page": "1200px"
  },
  "motion": {
    "ease":             "cubic-bezier(0.22, 1, 0.36, 1)",
    "ease-out-card":    "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "ease-in":          "cubic-bezier(0.4, 0, 1, 1)",
    "duration-chunk":   "150ms",
    "duration-state":   "200ms",
    "duration-fast":    "180ms",
    "duration-base":    "240ms",
    "duration-panel":   "240ms",
    "duration-hover":   "80ms",
    "duration-ring":    "180ms",
    "pulse-duration":   "1600ms",
    "spring-stiffness": "200",
    "spring-damping":   "15"
  },
  "shadow": {
    "none":              "none",
    "hover":             "inset 0 1px 0 0 rgba(255, 255, 255, 0.04)",
    "glow-accent":       "0 0 32px 0 rgba(59, 130, 246, 0.18)",
    "glow-accent-soft":  "0 0 16px 0 rgba(59, 130, 246, 0.12)",
    "glow-accent-lg":    "0 0 48px 0 rgba(59, 130, 246, 0.28)",
    "glow-done":         "0 0 24px 0 rgba(34, 197, 94, 0.22)",
    "glow-error":        "0 0 24px 0 rgba(239, 68, 68, 0.22)"
  },
  "z": {
    "base": 0,
    "raised": 10,
    "header": 30,
    "overlay": 40,
    "modal": 50,
    "toast": 60
  }
}
