{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "studio-mission-control",
    "version": "1.0.0",
    "stitchAssetId": "15972727176921104973",
    "mode": "dark"
  },
  "color": {
    "bg": "#05060A",
    "surface": "#0B0D14",
    "surface-raised": "#11141C",
    "surface-sunken": "#080A11",
    "surface-glass": "rgba(17, 20, 28, 0.6)",

    "text": "#F2F4F8",
    "text-muted": "#A0A6B8",
    "text-faint": "#5E6478",
    "text-on-primary": "#0A0410",

    "border": "rgba(255, 255, 255, 0.06)",
    "border-strong": "rgba(255, 255, 255, 0.12)",
    "border-primary": "rgba(124, 92, 255, 0.45)",

    "primary": "#7C5CFF",
    "primary-soft": "rgba(124, 92, 255, 0.18)",
    "primary-glow": "rgba(124, 92, 255, 0.35)",
    "secondary": "#22D3EE",
    "tertiary": "#F472B6",

    "success": "#34D399",
    "success-soft": "rgba(52, 211, 153, 0.18)",
    "warn": "#FBBF24",
    "error": "#F87171",
    "error-soft": "rgba(248, 113, 113, 0.18)"
  },
  "status": {
    "queued":  { "fg": "text-faint",  "dot": "outlined", "border": "border" },
    "running": { "fg": "primary",     "dot": "pulsing",  "border": "border-primary", "glow": "primary-soft" },
    "done":    { "fg": "success",     "dot": "filled",   "border": "border" },
    "error":   { "fg": "error",       "dot": "filled",   "border": "border" }
  },
  "font": {
    "display": "'Space Grotesk', system-ui, -apple-system, sans-serif",
    "body":    "'Inter', system-ui, -apple-system, sans-serif",
    "mono":    "'JetBrains Mono', ui-monospace, 'SF Mono', monospace"
  },
  "typography": {
    "display-lg":  { "font": "display", "size": "64px", "weight": "600", "lineHeight": "1.05", "letterSpacing": "-0.035em" },
    "display-md":  { "font": "display", "size": "44px", "weight": "600", "lineHeight": "1.08", "letterSpacing": "-0.03em" },
    "headline-lg": { "font": "display", "size": "28px", "weight": "600", "lineHeight": "1.2",  "letterSpacing": "-0.02em" },
    "headline-md": { "font": "display", "size": "20px", "weight": "600", "lineHeight": "1.25", "letterSpacing": "-0.015em" },
    "title-md":    { "font": "body",    "size": "15px", "weight": "600", "lineHeight": "1.3",  "letterSpacing": "-0.01em" },
    "body-md":     { "font": "body",    "size": "14px", "weight": "400", "lineHeight": "1.55" },
    "body-sm":     { "font": "body",    "size": "13px", "weight": "400", "lineHeight": "1.5" },
    "mono-md":     { "font": "mono",    "size": "12.5px", "weight": "400", "lineHeight": "1.55" },
    "mono-sm":     { "font": "mono",    "size": "11.5px", "weight": "400", "lineHeight": "1.45" },
    "label-sm":    { "font": "mono",    "size": "10.5px", "weight": "500", "lineHeight": "1.2", "letterSpacing": "0.08em", "transform": "uppercase" }
  },
  "radius": {
    "none": "0",
    "sm":   "6px",
    "md":   "10px",
    "lg":   "14px",
    "xl":   "20px",
    "full": "9999px"
  },
  "space": {
    "0": "0",
    "0.5": "2px",
    "1":   "4px",
    "2":   "8px",
    "3":   "12px",
    "4":   "16px",
    "5":   "20px",
    "6":   "24px",
    "8":   "32px",
    "10":  "40px",
    "12":  "48px",
    "16":  "64px",
    "20":  "80px"
  },
  "size": {
    "agent-card-h": "220px",
    "agent-grid-cols": "3",
    "agent-grid-cols-md": "2",
    "agent-grid-cols-sm": "1",
    "agent-grid-gap": "16px",
    "page-gutter": "24px",
    "page-gutter-sm": "16px",
    "section-gap": "48px",
    "row-sm": "44px",
    "row-md": "64px",
    "max-w-prose": "640px",
    "max-w-page": "1200px"
  },
  "motion": {
    "ease":     "cubic-bezier(0.22, 1, 0.36, 1)",
    "ease-in":  "cubic-bezier(0.4, 0, 1, 1)",
    "duration-micro": "150ms",
    "duration-state": "300ms",
    "duration-entry": "600ms"
  },
  "shadow": {
    "none":        "none",
    "hover":       "inset 0 1px 0 0 rgba(255, 255, 255, 0.04)",
    "glow-iris":   "0 0 32px 0 rgba(124, 92, 255, 0.18)",
    "glow-iris-lg":"0 0 48px 0 rgba(124, 92, 255, 0.28)",
    "glow-success":"0 0 24px 0 rgba(52, 211, 153, 0.22)",
    "glow-error":  "0 0 24px 0 rgba(248, 113, 113, 0.22)"
  },
  "blur": {
    "glass": "16px"
  },
  "gradient": {
    "iris-cta": "linear-gradient(135deg, #7C5CFF 0%, #22D3EE 100%)",
    "bloom":    "radial-gradient(60% 80% at 50% 0%, rgba(124, 92, 255, 0.25), transparent 70%)"
  },
  "z": {
    "base": 0,
    "raised": 10,
    "header": 30,
    "overlay": 40,
    "modal": 50,
    "toast": 60
  }
}
